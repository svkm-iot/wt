Practical 10: - File operations 
<?php 
 
while(true) 
{ 
    echo "\nMENU\n"; 
    echo "1. Create or Write File\n"; 
    echo "2. Read File\n"; 
    echo "3. Append File\n"; 
    echo "4. Delete File\n"; 
    echo "5. Exit\n"; 
 
    echo "Enter your choice: "; 
    $choice = trim(fgets(STDIN)); 
 
    echo "Enter file name: "; 
    $filename = trim(fgets(STDIN)); 
 
    switch($choice) 
    { 
        case 1: 
            $file = fopen($filename, "w"); 
 
            if($file) 
            { 
                echo "Enter content to write into the file: \n "; 
                $content = trim(fgets(STDIN)); 
 
                fwrite($file, $content); 
                fclose($file); 
                echo "File Created and content written Successfully...\n"; 
            } 
            else 
                echo "Error creating file.\n"; 
 
            break; 
             
        case 2: 
            if(file_exists($filename)) 
            { 
                $file = fopen($filename, "r"); 
                echo "File Content:\n"; 
                echo fread($file, filesize($filename)); 
                fclose($file); 
            } 
            else 
                echo "File does not exist\n"; 
             
            break; 
 
        case 3: 
            if(file_exists($filename)) 
            { 
                $file = fopen($filename, "a"); 
                echo "Enter Content to append:\n"; 
                $content = trim(fgets(STDIN)); 
 
                fwrite($file,"\n".$content); 
                fclose($file); 
                echo "Content Appended Successfully...\n"; 
            } 
            else 
                echo "File does not exist\n"; 
             
            break; 
 
        case 4: 
            if(file_exists($filename)) 
            { 
                unlink($filename); 
                echo "File deleted successfully\n"; 
            } 
            else 
                echo "File does not exist\n"; 
        break; 
 
        case 5: 
            echo "Exiting...\n"; 
            exit; 
 
        default: 
            echo "Invalid choice\n"; 
    } 
} 
?> 
