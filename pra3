    <tr><td>11.00 AM to 12.00 PM</td> 
        <td>2</td> 
        <td>OE-2</td> 
        <td>DM</td> 
        <td>DM</td> 
        <td>WT</td> 
        <td>UHV-2</td></tr> 
    <tr><td>12.00 PM to 01.00 PM</td> 
