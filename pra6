<?php 
$conn = mysqli_Connect("localhost", "root", "", "Person"); 
 
if ($_SERVER['REQUEST_METHOD'] == "POST") { 
//variables ($rollno, $name, $sub1…)  
//names given in form (roll, name, sub1,…) 
    $rollno = $_POST['roll']; 
    $name = $_POST['name']; 
    $sub1 = $_POST['sub1']; 
    $sub2 = $_POST['sub2']; 
    $sub3 = $_POST['sub3']; 
    $percentage = $_POST['percentage']; 
    $total = $_POST['total']; 
 
 //query to insert 
 //here `rollno` , `name` … are database table columns 
 // and '$rollno', '$name’ are variables 
    $sql = "INSERT INTO `students`  
 (`rollno`, `name`, `sub1`, `sub2` , `sub3`, `per`, `total`)  
VALUES ('$rollno', '$name', '$sub1', '$sub2', '$sub3',  
'$percentage', '$total');"; 
 
    $result = mysqli_query($conn, $sql); 
    if ($result) 
        echo "Data inserted successfully..." . "<br>"; 
    else 
        echo "Data not inserted: " . mysqli_error($conn) . "<br>"; 
} 
?> 
